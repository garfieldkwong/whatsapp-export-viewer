{
  "name": "whatsapp-export-viewer",
  "version": "1.0.0",
  "description": "Local web viewer for WhatsApp ZIP exports with lazy loading and WhatsApp-style UI",
  "main": "dist/server/index.js",
  "type": "module",
  "scripts": {
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc",
    "build:client": "vite build",
    "start": "node dist/server/index.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsc --watch",
    "dev:client": "vite"
  },
  "keywords": [
    "whatsapp",
    "export",
    "viewer",
    "chat"
  ],
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.1",
    "express": "^4.21.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "vue": "^3.5.34",
    "yauzl": "^3.3.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.12",
    "@types/chokidar": "^1.7.5",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pino": "^7.0.4",
    "@types/yauzl": "^2.10.3",
    "@vitejs/plugin-vue": "^5.2.4",
    "concurrently": "^9.1.2",
    "esbuild": "^0.24.2",
    "nodemon": "^3.1.9",
    "typescript": "^5.7.2",
    "vite": "^6.4.2"
  }
}
